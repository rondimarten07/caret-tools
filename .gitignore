# ─── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build output ─────────────────────────────────────────
dist/
dist-ssr/
build/
*.tsbuildinfo

# Vite emits these from vite.config.ts when running tsc — source of truth is .ts
vite.config.js
vite.config.d.ts

# ─── Local env / secrets ──────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example tracked — it documents available env vars

# ─── OS / editor noise ────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor folders
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.iml

# ─── Logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ─── Test / coverage ──────────────────────────────────────
coverage/
.nyc_output/

# ─── Vercel / Netlify local ───────────────────────────────
.vercel
.netlify

# ─── PWA generated (regenerated on build) ─────────────────
dev-dist/

# ─── Misc cache ───────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
